{
  "name": "pipes-example-factories",
  "version": "0.0.1",
  "private": true,
  "description": "Example Pipes project demonstrating project-local architecture",
  "type": "module",
  "scripts": {
    "doctor": "tsx ../src/cli.ts doctor --config ./pipes.config.ts",
    "notion:setup": "tsx ../src/cli.ts integrations notion setup --config ./pipes.config.ts",
    "notion:sync": "tsx ../src/cli.ts integrations notion sync --config ./pipes.config.ts",
    "notion:create-task": "tsx ../src/cli.ts integrations notion create-task --config ./pipes.config.ts",
    "notion:repair-task": "tsx ../src/cli.ts integrations notion repair-task --config ./pipes.config.ts",
    "tick": "tsx ../src/cli.ts tick --config ./pipes.config.ts",
    "tick:demo": "tsx ../src/cli.ts tick --pipe shared-helper-demo --config ./pipes.config.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "notionflow": "file:.."
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.9.2"
  }
}
